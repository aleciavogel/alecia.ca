{
  "name": "alecia.ca",
  "description": "My personal blog and portfolio, build in NextJS, typescript React, and TailwindCSS",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --fix --ext .jsx --ext .js --ext .tsx --ext .ts .",
    "cy:open": "start-server-and-test develop http://localhost:8000 cy:open",
    "cy:run": "start-server-and-test develop http://localhost:8000 cy:run",
    "prettier": "prettier --write './src/**/*.{js,jsx,ts,tsx}'"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{html,css,scss,sass}": [
      "prettier --write"
    ]
  },
  "dependencies": {
